{
  "name": "ShoutOut",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "title": "User Email"
    },
    "username": {
      "type": "string",
      "title": "Username"
    },
    "content": {
      "type": "string",
      "title": "Content"
    },
    "likes": {
      "type": "number",
      "title": "Likes",
      "default": 0
    },
    "liked_by": {
      "type": "string",
      "title": "Liked By (JSON array)",
      "default": "[]"
    },
    "age_group": {
      "type": "string",
      "title": "Age Group"
    },
    "media_url": {
      "type": "string",
      "title": "Media URL (photo/video)"
    },
    "media_type": {
      "type": "string",
      "title": "Media Type",
      "enum": [
        "image",
        "video"
      ]
    },
    "status": {
      "type": "string",
      "title": "Moderation Status",
      "enum": [
        "pending",
        "approved",
        "rejected",
        "flagged"
      ],
      "default": "approved"
    },
    "approved_by": {
      "type": "string",
      "title": "Approved By (Admin Email)"
    },
    "approved_date": {
      "type": "string",
      "title": "Approved Date"
    },
    "rejected_by": {
      "type": "string",
      "title": "Rejected By (Admin Email)"
    },
    "rejected_date": {
      "type": "string",
      "title": "Rejected Date"
    },
    "rejection_reason": {
      "type": "string",
      "title": "Rejection Reason"
    }
  },
  "required": [
    "user_email",
    "content"
  ]
}