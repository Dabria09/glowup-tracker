{
  "name": "SupportTicket",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "title": "User Email"
    },
    "user_id": {
      "type": "string",
      "title": "User ID"
    },
    "title": {
      "type": "string",
      "title": "Title"
    },
    "description": {
      "type": "string",
      "title": "Description"
    },
    "category": {
      "type": "string",
      "title": "Category",
      "enum": [
        "bug",
        "account",
        "content",
        "billing",
        "safety_concern",
        "technical_issue",
        "feedback",
        "feature_request",
        "accessibility",
        "privacy",
        "other"
      ],
      "default": "other"
    },
    "priority": {
      "type": "string",
      "title": "Priority",
      "enum": [
        "low",
        "medium",
        "high",
        "urgent"
      ],
      "default": "medium"
    },
    "status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "open",
        "in_progress",
        "resolved",
        "closed"
      ],
      "default": "open"
    },
    "admin_notes": {
      "type": "string",
      "title": "Admin Notes"
    },
    "resolved_date": {
      "type": "string",
      "title": "Resolved Date"
    },
    "escalated_to_moderation": {
      "type": "boolean",
      "title": "Escalated to Moderation",
      "default": false
    },
    "linked_content_report_id": {
      "type": "string",
      "title": "Linked Content Report ID"
    },
    "safety_keywords_detected": {
      "type": "string",
      "title": "Safety Keywords Detected (JSON array)",
      "default": "[]"
    },
    "admin_replies": {
      "type": "string",
      "title": "Admin Replies (JSON array)",
      "default": "[]"
    },
    "last_admin_reply": {
      "type": "string",
      "title": "Last Admin Reply Date"
    }
  },
  "required": [
    "title",
    "category"
  ]
}