{
  "name": "TeamMember",
  "type": "object",
  "properties": {
    "team_id": {
      "type": "string",
      "title": "Team ID"
    },
    "user_email": {
      "type": "string",
      "title": "User Email"
    },
    "role": {
      "type": "string",
      "enum": [
        "member",
        "admin",
        "moderator"
      ],
      "default": "member",
      "title": "Role"
    },
    "joined_date": {
      "type": "string",
      "title": "Joined Date"
    },
    "contribution_points": {
      "type": "number",
      "title": "Contribution Points",
      "default": 0
    }
  },
  "required": [
    "team_id",
    "user_email"
  ]
}